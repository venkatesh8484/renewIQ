# Copy this to .env and fill in your values. Never commit .env.

# ── LLM Backend ────────────────────────────────────────────────────────────────
# "ollama"      → local Ollama (free, for development)
# "databricks"  → DBRX via Databricks AI Gateway (for production/demo)
LLM_BACKEND=ollama

# ── Ollama (local dev) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Databricks ─────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://<your-workspace>.azuredatabricks.net
DATABRICKS_TOKEN=<your-pat-token>
DATABRICKS_SERVING_ENDPOINT=renewiq-agent-endpoint

# ── Redis (local dev cache) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API ────────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-change-in-prod
LOG_LEVEL=INFO

# ── Mock mode (offline dev without Databricks) ────────────────────────────────
USE_MOCK_ENDPOINT=false
